# Copy to .env and adjust. The app reads plain environment variables.

# Address the HTTP server binds to.
LISTEN_ADDR=:8080

# Externally reachable base URL. redirect_uri (OIDC) and ACS URL (SAML) are
# derived from this and must match what is registered at the identity provider.
# For a public tunnel set e.g. https://your-tunnel.ngrok.app
BASE_URL=http://localhost:8080

# Storage backend: "postgres" (external database, default) or "sqlite"
# (embedded, file-backed — no external service).
DB_DRIVER=postgres

# PostgreSQL connection string (used when DB_DRIVER=postgres).
POSTGRES_DSN=postgres://loupe:loupe@localhost:5432/loupe?sslmode=disable

# SQLite database file path (used when DB_DRIVER=sqlite).
SQLITE_PATH=loupe.db

# Master key for encrypting secrets at rest. Any non-empty passphrase works;
# it is hashed (SHA-256) to derive the AES-256 key. Keep it stable, or
# previously stored secrets won't decrypt.
MASTER_KEY=
